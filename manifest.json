{
  "manifest_version": 3,
  "name": "InsightSnap AI",
  "description": "Summarize the current webpage into key points, actions, and keywords.",
  "version": "0.2.0",
  "permissions": ["activeTab", "scripting", "clipboardWrite"],
  "action": {
    "default_title": "InsightSnap AI",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
